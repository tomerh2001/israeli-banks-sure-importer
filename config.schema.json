{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Config",
  "definitions": {
    "Config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "banks",
        "output"
      ],
      "properties": {
        "banks": {
          "$ref": "#/definitions/ConfigBanks"
        },
        "output": {
          "$ref": "#/definitions/ConfigOutput"
        }
      }
    },
    "ConfigBanks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ConfigBank"
      }
    },
    "ConfigOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory"
      ],
      "properties": {
        "directory": {
          "type": "string"
        },
        "format": {
          "$ref": "#/definitions/OutputFormat"
        },
        "pretty": {
          "type": "boolean"
        }
      }
    },
    "OutputFormat": {
      "type": "string",
      "enum": [
        "json",
        "csv",
        "json-and-csv"
      ]
    },
    "AccountsSelector": {
      "anyOf": [
        {
          "const": "all"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "ConfigBankUserCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "userCode",
        "password"
      ],
      "properties": {
        "userCode": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        }
      }
    },
    "ConfigBankUsername": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        }
      }
    },
    "ConfigBankId": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "password"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        }
      }
    },
    "ConfigBankIdNum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "num",
        "password"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "num": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        }
      }
    },
    "ConfigBank": {
      "anyOf": [
        {
          "$ref": "#/definitions/ConfigBankUserCode"
        },
        {
          "$ref": "#/definitions/ConfigBankUsername"
        },
        {
          "$ref": "#/definitions/ConfigBankId"
        },
        {
          "$ref": "#/definitions/ConfigBankIdNum"
        }
      ]
    }
  }
}
