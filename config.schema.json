{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Config",
  "definitions": {
    "Config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "banks",
        "sure"
      ],
      "properties": {
        "banks": {
          "$ref": "#/definitions/ConfigBanks"
        },
        "sure": {
          "$ref": "#/definitions/ConfigSure"
        }
      }
    },
    "ConfigBanks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ConfigBank"
      }
    },
    "ConfigSure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apiKey",
        "baseUrl"
      ],
      "properties": {
        "apiKey": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "createMissingTags": {
          "type": "boolean"
        },
        "defaultTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "AccountsSelector": {
      "anyOf": [
        {
          "const": "all"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "TargetCategoryMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "ConfigBankTargetById": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sureAccountId"
      ],
      "properties": {
        "sureAccountId": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        },
        "alias": {
          "type": "string"
        },
        "categoryMap": {
          "$ref": "#/definitions/TargetCategoryMap"
        },
        "reconcile": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ConfigBankTargetByName": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sureAccountName"
      ],
      "properties": {
        "sureAccountName": {
          "type": "string"
        },
        "accounts": {
          "$ref": "#/definitions/AccountsSelector"
        },
        "alias": {
          "type": "string"
        },
        "categoryMap": {
          "$ref": "#/definitions/TargetCategoryMap"
        },
        "reconcile": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ConfigBankTarget": {
      "anyOf": [
        {
          "$ref": "#/definitions/ConfigBankTargetById"
        },
        {
          "$ref": "#/definitions/ConfigBankTargetByName"
        }
      ]
    },
    "ConfigBankUserCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "password",
        "targets",
        "userCode"
      ],
      "properties": {
        "userCode": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ConfigBankTarget"
          }
        }
      }
    },
    "ConfigBankUsername": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "password",
        "targets",
        "username"
      ],
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ConfigBankTarget"
          }
        }
      }
    },
    "ConfigBankId": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "password",
        "targets"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ConfigBankTarget"
          }
        }
      }
    },
    "ConfigBankIdNum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "num",
        "password",
        "targets"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "num": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ConfigBankTarget"
          }
        }
      }
    },
    "ConfigBank": {
      "anyOf": [
        {
          "$ref": "#/definitions/ConfigBankUserCode"
        },
        {
          "$ref": "#/definitions/ConfigBankUsername"
        },
        {
          "$ref": "#/definitions/ConfigBankId"
        },
        {
          "$ref": "#/definitions/ConfigBankIdNum"
        }
      ]
    }
  }
}
